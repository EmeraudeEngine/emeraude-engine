---
Checks: >
  -*,
  clang-analyzer-*,
  concurrency-*,
  misc-*,
  -misc-multiple-inheritance,
  -misc-include-cleaner,
  mpi-*,
  openmp-*,
  performance-*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  cert-err52-cpp,
  cert-err60-cpp,
  cert-err34-c,
  cert-str34-c,
  cert-msc50-cpp,
  cert-msc51-cpp,
  cert-dcl58-cpp,
  cert-flp30-c,
  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-magic-numbers,modernize-*,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-bounds-avoid-unchecked-container-access,
  -modernize-use-trailing-return-type,
  portability-*,
  -portability-avoid-pragma-once,
  readability-*,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-suspicious-call-argument,
  -readability-function-cognitive-complexity,
  -clang-diagnostic-unreachable-code
WarningsAsErrors: ''
HeaderFilterRegex: 'src/.*'
FormatStyle: file
ExtraArgs:
  - '-Wno-unknown-warning-option'
CheckOptions:
  # Skip true data-holder types (struct/class where every member is public).
  # The check still fires on classes that mix public/protected/private members,
  # which is the real code smell to catch (encapsulation leak).
  misc-non-private-member-variables-in-classes.IgnoreClassesWithAllMemberVariablesBeingPublic: true
  cppcoreguidelines-non-private-member-variables-in-classes.IgnoreClassesWithAllMemberVariablesBeingPublic: true
